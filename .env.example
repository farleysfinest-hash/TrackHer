# ── Supabase (required for real auth + data, Phase 2+) ──
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# ── Dev / demo mode ──
# true  = mock data, no Supabase, no signup (good for UI testing)
# false = real Supabase backend (required for production)
VITE_DEV_MODE=false

# ── Suggested setups ──
#
# Local UI demo:
#   VITE_DEV_MODE=true
#   (Supabase vars can be omitted)
#
# Local + shared test database:
#   VITE_DEV_MODE=false
#   VITE_SUPABASE_URL=<test project URL>
#   VITE_SUPABASE_ANON_KEY=<test anon key>
#
# Vercel Phase 1 (send link to tester, mock data):
#   VITE_DEV_MODE=true
#
# Vercel Phase 2+ (real accounts):
#   VITE_DEV_MODE=false
#   VITE_SUPABASE_URL=<test or prod project URL>
#   VITE_SUPABASE_ANON_KEY=<anon key>
#
# See docs/DEPLOYMENT.md for full setup.
