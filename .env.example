# ── Supabase (required) ──
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# ── Public web origin (required for password-reset emails from the iOS app) ──
# No trailing slash. Must also be listed in Supabase Auth → Redirect URLs.
VITE_APP_URL=https://trackher.app

# ── RevenueCat (optional until App Store products exist) ──
# Public iOS SDK key from RevenueCat → Project settings → API keys.
# When unset, Pro features stay unlocked for web / private beta.
# VITE_REVENUECAT_IOS_API_KEY=appl_xxxxxxxx

# Copy this file to `.env` and fill in your project credentials.
# See docs/DEPLOYMENT.md for full setup.
